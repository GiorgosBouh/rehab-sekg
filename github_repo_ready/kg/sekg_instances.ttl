@prefix sekg: <https://example.org/sekg/rehab#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/sekg/rehab/instances> a owl:Ontology ;
    owl:imports <https://example.org/sekg/rehab> ;
    dcterms:title "Representative instances for the rehabilitation SEKG ontology" ;
    dcterms:created "2026-07-08"^^xsd:date .

sekg:RepresentativeSampleSet a sekg:ProofOfConceptSampleSet ;
    rdfs:label "Representative rehabilitation SEKG sample set" ;
    sekg:includesRepresentativeRecord sekg:MEx_Subject01_Exercise01,
        sekg:PhysioNet_GaPt03_01,
        sekg:KEDEEA_Case_001,
        sekg:KEDEEA_Case_002,
        sekg:KEDEEA_Case_003 ;
    sekg:integrationAssumption "Records are independent examples from different data sources; they are not modeled as the same patient, organization, or care episode." .

sekg:DemoRehabilitationCenter a sekg:RehabilitationEnterprise ;
    rdfs:label "Demo interdisciplinary rehabilitation center" ;
    sekg:hasDepartment sekg:PhysiotherapyDepartment,
        sekg:OccupationalTherapyDepartment,
        sekg:GaitLaboratory,
        sekg:ClinicalDataOffice ;
    sekg:hasEnterpriseProcess sekg:RehabilitationCarePathway,
        sekg:SEKGGovernanceProcess ;
    sekg:hasEnterpriseRole sekg:PhysiotherapistRole,
        sekg:OccupationalTherapistRole,
        sekg:DataStewardRole,
        sekg:DomainExpertRole,
        sekg:LLMAssistantRole ;
    sekg:hasModelingWorkflow sekg:HumanLLMCollaborativeModelingWorkflow ;
    sekg:hasValueProposition sekg:RehabilitationValueProposition ;
    sekg:alignsWithExternalStandard sekg:FHIRStandard,
        sekg:ICFStandard,
        sekg:UMLSStandard,
        sekg:SNOMEDCTStandard ;
    sekg:usesExternalDataset sekg:MEx,
        sekg:PhysioNetGaitPDB ;
    sekg:usesLocalClinicalSource sekg:KEDEEA_LocalClinicalCases .

sekg:PhysiotherapyDepartment a sekg:Department ;
    rdfs:label "Physiotherapy department" ;
    sekg:departmentResponsibility "Movement assessment, physiotherapy intervention planning, and interpretation of physiotherapy-relevant cases and recordings." .

sekg:OccupationalTherapyDepartment a sekg:Department ;
    rdfs:label "Occupational therapy department" ;
    sekg:departmentResponsibility "Assessment of activities of daily living, cognition, play, interaction, participation, and occupational performance." .

sekg:GaitLaboratory a sekg:Department ;
    rdfs:label "Gait and movement analysis laboratory" ;
    sekg:departmentResponsibility "Sensor-based gait and movement data capture, preprocessing, and measurement interpretation." .

sekg:ClinicalDataOffice a sekg:Department ;
    rdfs:label "Clinical data governance office" ;
    sekg:departmentResponsibility "Data provenance, privacy treatment, ontology governance, and human validation of graph changes." .

sekg:PhysiotherapistRole a sekg:ProfessionalRole ;
    rdfs:label "Physiotherapist" ;
    sekg:assignedToDepartment sekg:PhysiotherapyDepartment,
        sekg:GaitLaboratory ;
    sekg:supportsWorkflow sekg:HumanLLMCollaborativeModelingWorkflow ;
    sekg:enterpriseResponsibility "Interprets physiotherapy cases, movement measurements, gait information, and exercise-recording variables." ;
    sekg:interpretsRecord sekg:MEx_Subject01_Exercise01,
        sekg:PhysioNet_GaPt03_01,
        sekg:KEDEEA_Case_003 .

sekg:OccupationalTherapistRole a sekg:ProfessionalRole ;
    rdfs:label "Occupational therapist" ;
    sekg:assignedToDepartment sekg:OccupationalTherapyDepartment ;
    sekg:supportsWorkflow sekg:HumanLLMCollaborativeModelingWorkflow ;
    sekg:enterpriseResponsibility "Interprets occupational therapy assessments, activities of daily living, cognition, participation, and intervention focus." ;
    sekg:interpretsRecord sekg:KEDEEA_Case_001,
        sekg:KEDEEA_Case_002 .

sekg:DataStewardRole a sekg:ProfessionalRole ;
    rdfs:label "Clinical data steward" ;
    sekg:assignedToDepartment sekg:ClinicalDataOffice ;
    sekg:supportsWorkflow sekg:HumanLLMCollaborativeModelingWorkflow ;
    sekg:enterpriseResponsibility "Checks source provenance, privacy treatment, sample documentation, and data-to-ontology traceability." ;
    sekg:validatesProvenance sekg:RepresentativeSampleSet .

sekg:DomainExpertRole a sekg:ProfessionalRole ;
    rdfs:label "Rehabilitation domain expert" ;
    sekg:assignedToDepartment sekg:ClinicalDataOffice ;
    sekg:supportsWorkflow sekg:HumanLLMCollaborativeModelingWorkflow ;
    sekg:enterpriseResponsibility "Validates clinical meaning, organizational fit, ontology mappings, and final acceptance of candidate graph changes." ;
    sekg:validatesCandidateModel sekg:HumanLLMCollaborativeModelingWorkflow .

sekg:LLMAssistantRole a sekg:ComputationalAssistantRole ;
    rdfs:label "LLM modeling assistant" ;
    sekg:assignedToDepartment sekg:ClinicalDataOffice ;
    sekg:supportsWorkflow sekg:HumanLLMCollaborativeModelingWorkflow ;
    sekg:enterpriseResponsibility "Suggests candidate ontology concepts, mappings, documentation, and SPARQL queries for human review." .

sekg:HumanLLMCollaborativeModelingWorkflow a sekg:ModelingWorkflow ;
    rdfs:label "Human-LLM collaborative SEKG modeling workflow" ;
    sekg:hasWorkflowStage sekg:CandidateSuggestionStage,
        sekg:ProvenanceReviewStage,
        sekg:ClinicalValidationStage,
        sekg:GovernanceDecisionStage,
        sekg:GraphReleaseStage ;
    sekg:usesSampleSet sekg:RepresentativeSampleSet ;
    sekg:llmTask "Propose candidate concepts, relationships, mappings, and natural-language queries." ;
    sekg:humanTask "Validate clinical meaning, organizational fit, governance rules, and final graph changes." .

sekg:RehabilitationValueProposition a sekg:ValueProposition ;
    rdfs:label "Coordinated rehabilitation value proposition" ;
    sekg:valueDescription "Support coordinated interdisciplinary rehabilitation by making cases, assessments, functional domains, sensor evidence, roles, provenance, and governance decisions semantically traceable." .

sekg:RehabilitationCarePathway a sekg:EnterpriseProcess ;
    rdfs:label "Representative rehabilitation care pathway" ;
    sekg:supportsValueProposition sekg:RehabilitationValueProposition ;
    sekg:hasWorkflowStage sekg:ReferralAndIntakeStage,
        sekg:InitialAssessmentStage,
        sekg:GoalSettingStage,
        sekg:InterventionPlanningStage,
        sekg:TherapyDeliveryStage,
        sekg:ReassessmentStage,
        sekg:DischargeOrResearchReuseStage .

sekg:ReferralAndIntakeStage a sekg:WorkflowStage ;
    rdfs:label "Referral and intake" ;
    sekg:stageOrder "1"^^xsd:integer ;
    sekg:stagePurpose "Register the case context and establish the data source and privacy treatment." ;
    sekg:stageResponsibleRole sekg:DataStewardRole ;
    sekg:nextStage sekg:InitialAssessmentStage .

sekg:InitialAssessmentStage a sekg:WorkflowStage ;
    rdfs:label "Initial assessment" ;
    sekg:stageOrder "2"^^xsd:integer ;
    sekg:stagePurpose "Capture clinical assessment instruments, functional domains, observed variables, and relevant sensor evidence." ;
    sekg:stageResponsibleRole sekg:OccupationalTherapistRole,
        sekg:PhysiotherapistRole ;
    sekg:nextStage sekg:GoalSettingStage .

sekg:GoalSettingStage a sekg:WorkflowStage ;
    rdfs:label "Goal setting" ;
    sekg:stageOrder "3"^^xsd:integer ;
    sekg:stagePurpose "Translate assessment findings into rehabilitation goals and priority functional domains." ;
    sekg:stageResponsibleRole sekg:OccupationalTherapistRole,
        sekg:PhysiotherapistRole ;
    sekg:nextStage sekg:InterventionPlanningStage .

sekg:InterventionPlanningStage a sekg:WorkflowStage ;
    rdfs:label "Intervention planning" ;
    sekg:stageOrder "4"^^xsd:integer ;
    sekg:stagePurpose "Connect goals, clinical conditions, assessments, and responsible professionals to planned interventions." ;
    sekg:stageResponsibleRole sekg:OccupationalTherapistRole,
        sekg:PhysiotherapistRole ;
    sekg:nextStage sekg:TherapyDeliveryStage .

sekg:TherapyDeliveryStage a sekg:WorkflowStage ;
    rdfs:label "Therapy delivery" ;
    sekg:stageOrder "5"^^xsd:integer ;
    sekg:stagePurpose "Deliver occupational therapy, physiotherapy, and movement-analysis activities using the relevant enterprise roles and data." ;
    sekg:stageResponsibleRole sekg:OccupationalTherapistRole,
        sekg:PhysiotherapistRole ;
    sekg:nextStage sekg:ReassessmentStage .

sekg:ReassessmentStage a sekg:WorkflowStage ;
    rdfs:label "Re-assessment" ;
    sekg:stageOrder "6"^^xsd:integer ;
    sekg:stagePurpose "Re-evaluate functional domains and compare assessment evidence over time." ;
    sekg:stageResponsibleRole sekg:OccupationalTherapistRole,
        sekg:PhysiotherapistRole ;
    sekg:nextStage sekg:DischargeOrResearchReuseStage .

sekg:DischargeOrResearchReuseStage a sekg:WorkflowStage ;
    rdfs:label "Discharge or research reuse" ;
    sekg:stageOrder "7"^^xsd:integer ;
    sekg:stagePurpose "Summarize outcomes, preserve provenance, and enable approved research reuse of de-identified evidence." ;
    sekg:stageResponsibleRole sekg:DataStewardRole,
        sekg:DomainExpertRole .

sekg:SEKGGovernanceProcess a sekg:EnterpriseProcess ;
    rdfs:label "SEKG change-governance process" ;
    sekg:supportsValueProposition sekg:RehabilitationValueProposition ;
    sekg:hasWorkflowStage sekg:CandidateSuggestionStage,
        sekg:ProvenanceReviewStage,
        sekg:ClinicalValidationStage,
        sekg:GovernanceDecisionStage,
        sekg:GraphReleaseStage .

sekg:CandidateSuggestionStage a sekg:WorkflowStage ;
    rdfs:label "Candidate suggestion" ;
    sekg:stageOrder "1"^^xsd:integer ;
    sekg:stagePurpose "Suggest candidate classes, properties, mappings, documentation, or SPARQL queries." ;
    sekg:governanceCriterion "LLM output is treated as a candidate artifact, never as an approved graph change." ;
    sekg:stageResponsibleRole sekg:LLMAssistantRole ;
    sekg:nextStage sekg:ProvenanceReviewStage .

sekg:ProvenanceReviewStage a sekg:WorkflowStage ;
    rdfs:label "Provenance and privacy review" ;
    sekg:stageOrder "2"^^xsd:integer ;
    sekg:stagePurpose "Check source traceability, privacy treatment, and whether the change can be justified from available evidence." ;
    sekg:governanceCriterion "Changes without acceptable provenance or privacy treatment are rejected or revised." ;
    sekg:stageResponsibleRole sekg:DataStewardRole ;
    sekg:nextStage sekg:ClinicalValidationStage .

sekg:ClinicalValidationStage a sekg:WorkflowStage ;
    rdfs:label "Clinical validation" ;
    sekg:stageOrder "3"^^xsd:integer ;
    sekg:stagePurpose "Validate clinical meaning, rehabilitation fit, and role responsibility assignments." ;
    sekg:governanceCriterion "Clinically ambiguous mappings require expert revision before acceptance." ;
    sekg:stageResponsibleRole sekg:DomainExpertRole,
        sekg:OccupationalTherapistRole,
        sekg:PhysiotherapistRole ;
    sekg:nextStage sekg:GovernanceDecisionStage .

sekg:GovernanceDecisionStage a sekg:WorkflowStage ;
    rdfs:label "Governance decision" ;
    sekg:stageOrder "4"^^xsd:integer ;
    sekg:stagePurpose "Record whether the candidate change is accepted, revised, rejected, or postponed." ;
    sekg:governanceCriterion "Accepted changes must have a human validation decision and a traceable source." ;
    sekg:stageResponsibleRole sekg:DomainExpertRole,
        sekg:DataStewardRole ;
    sekg:nextStage sekg:GraphReleaseStage .

sekg:GraphReleaseStage a sekg:WorkflowStage ;
    rdfs:label "Graph release" ;
    sekg:stageOrder "5"^^xsd:integer ;
    sekg:stagePurpose "Update ontology, instances, demo artifacts, and competency-query results after accepted changes." ;
    sekg:governanceCriterion "Competency questions and coverage checks are re-run after accepted graph changes." ;
    sekg:stageResponsibleRole sekg:DataStewardRole .

sekg:FHIRStandard a sekg:ExternalStandard ;
    rdfs:label "FHIR" ;
    sekg:standardUse "Reference point for clinical data exchange; the SEKG can link to exchanged clinical resources rather than replace FHIR." .

sekg:ICFStandard a sekg:ExternalStandard ;
    rdfs:label "ICF" ;
    sekg:standardUse "Reference point for functioning, activity, participation, and environmental-factor classification." .

sekg:UMLSStandard a sekg:ExternalStandard ;
    rdfs:label "UMLS" ;
    sekg:standardUse "Reference point for biomedical terminology integration and concept normalization." .

sekg:SNOMEDCTStandard a sekg:ExternalStandard ;
    rdfs:label "SNOMED CT" ;
    sekg:standardUse "Reference point for clinical terminology alignment where licensing and implementation context permit it." .

#################################################################
# Data sources
#################################################################

sekg:KEDEEA_LocalClinicalCases a sekg:LocalClinicalCaseSource ;
    rdfs:label "KEDEEA local de-identified clinical cases" ;
    sekg:sourceContext "Local occupational therapy and physiotherapy assessment files" ;
    sekg:sourceDocumentCount "3"^^xsd:integer ;
    sekg:privacyTreatment "Direct identifiers from the source files are excluded from the derived sample CSV and knowledge graph." ;
    sekg:sampleFile "data/samples/kedeea_cases_deidentified.csv" ;
    sekg:capturesVariable sekg:CaseAgeGroupVariable,
        sekg:CaseAssessmentPeriodVariable,
        sekg:CaseConditionSummaryVariable,
        sekg:CaseAssessmentInstrumentsVariable,
        sekg:CaseFunctionalDomainsVariable,
        sekg:CaseInterventionFocusVariable .

sekg:MEx a sekg:OpenRehabilitationDataset ;
    rdfs:label "MEx Multi-modal Exercise dataset" ;
    dcterms:source <https://archive.ics.uci.edu/dataset/500/mex> ;
    dcterms:identifier "doi:10.24432/C59K6T" ;
    sekg:subjectCount "30"^^xsd:integer ;
    sekg:exerciseCount "7"^^xsd:integer ;
    sekg:instanceCount "6262"^^xsd:integer ;
    sekg:hasModality sekg:ThighAccelerometer,
        sekg:WristAccelerometer,
        sekg:DepthCamera,
        sekg:PressureMat ;
    sekg:capturesVariable sekg:TimestampVariable,
        sekg:AccelerationXVariable,
        sekg:AccelerationYVariable,
        sekg:AccelerationZVariable,
        sekg:DepthFeatureVectorVariable,
        sekg:PressureFeatureVectorVariable ;
    sekg:clinicalFocus "Physiotherapy exercise recognition, counting, and quality assessment." .

sekg:PhysioNetGaitPDB a sekg:OpenGaitDataset ;
    rdfs:label "PhysioNet Gait in Parkinson's Disease" ;
    dcterms:source <https://physionet.org/content/gaitpdb/1.0.0/> ;
    dcterms:identifier "doi:10.13026/C24H3N" ;
    sekg:patientCount "93"^^xsd:integer ;
    sekg:controlCount "73"^^xsd:integer ;
    sekg:sampleRateHz "100"^^xsd:decimal ;
    sekg:hasModality sekg:FootForceSensorArray ;
    sekg:capturesVariable sekg:TimeSecondsVariable,
        sekg:LeftFootSensorForceVariable,
        sekg:RightFootSensorForceVariable,
        sekg:LeftTotalForceVariable,
        sekg:RightTotalForceVariable ;
    sekg:clinicalFocus "Parkinson's disease gait analysis using vertical ground reaction force recordings." .

#################################################################
# Representative clinical cases
#################################################################

sekg:KEDEEA_Case_001 a sekg:DeidentifiedClinicalCase ;
    rdfs:label "KEDEEA de-identified clinical case 001" ;
    sekg:hasSourceData sekg:KEDEEA_LocalClinicalCases ;
    sekg:serviceArea sekg:OccupationalTherapy ;
    sekg:ageGroup "Preschool child" ;
    sekg:assessmentPeriod "2025-Q4" ;
    sekg:condition sekg:DevelopmentalImmaturity ;
    sekg:usesAssessmentInstrument sekg:ClinicalObservation ;
    sekg:hasFunctionalDomain sekg:AdaptationAndSeparation,
        sekg:Attention,
        sekg:PlayAndInteraction,
        sekg:Cognition,
        sekg:GrossMotorFunction,
        sekg:FineMotorFunction,
        sekg:ActivitiesOfDailyLiving ;
    sekg:hasObservedVariable sekg:CaseAgeGroupVariable,
        sekg:CaseAssessmentPeriodVariable,
        sekg:CaseConditionSummaryVariable,
        sekg:CaseAssessmentInstrumentsVariable,
        sekg:CaseFunctionalDomainsVariable,
        sekg:CaseInterventionFocusVariable ;
    sekg:interventionFocus "Engagement in activities, interaction, attention, basic concepts, and gross and fine motor skills." .

sekg:KEDEEA_Case_002 a sekg:DeidentifiedClinicalCase ;
    rdfs:label "KEDEEA de-identified clinical case 002" ;
    sekg:hasSourceData sekg:KEDEEA_LocalClinicalCases ;
    sekg:serviceArea sekg:OccupationalTherapy ;
    sekg:ageGroup "Young adult" ;
    sekg:assessmentPeriod "2025-Q1 and 2026-Q1" ;
    sekg:condition sekg:CerebralPalsy ;
    sekg:usesAssessmentInstrument sekg:MoCA,
        sekg:BOT2,
        sekg:ModifiedBarthelIndex,
        sekg:CanadianOccupationalPerformanceMeasure ;
    sekg:hasFunctionalDomain sekg:Cognition,
        sekg:VisualSpatialPerception,
        sekg:GrossMotorFunction,
        sekg:FineMotorFunction,
        sekg:Balance,
        sekg:ActivitiesOfDailyLiving,
        sekg:CommunityParticipation ;
    sekg:hasObservedVariable sekg:CaseAgeGroupVariable,
        sekg:CaseAssessmentPeriodVariable,
        sekg:CaseConditionSummaryVariable,
        sekg:CaseAssessmentInstrumentsVariable,
        sekg:CaseFunctionalDomainsVariable,
        sekg:CaseInterventionFocusVariable ;
    sekg:interventionFocus "Autonomy, activities of daily living, attention, memory, visual perception, balance, and trunk stability." .

sekg:KEDEEA_Case_003 a sekg:DeidentifiedClinicalCase ;
    rdfs:label "KEDEEA de-identified clinical case 003" ;
    sekg:hasSourceData sekg:KEDEEA_LocalClinicalCases ;
    sekg:serviceArea sekg:Physiotherapy ;
    sekg:ageGroup "Middle-aged adult" ;
    sekg:assessmentPeriod "2025-Q4" ;
    sekg:condition sekg:CerebralPalsy ;
    sekg:usesAssessmentInstrument sekg:VASPainScale,
        sekg:RangeOfMotionAssessment,
        sekg:ManualMuscleTesting,
        sekg:FunctionalGaitAssessment,
        sekg:AssistiveDeviceReview ;
    sekg:hasFunctionalDomain sekg:Pain,
        sekg:Posture,
        sekg:Balance,
        sekg:FallsRisk,
        sekg:Gait,
        sekg:RangeOfMotion,
        sekg:MuscleStrength,
        sekg:AssistiveDeviceUse ;
    sekg:hasObservedVariable sekg:CaseAgeGroupVariable,
        sekg:CaseAssessmentPeriodVariable,
        sekg:CaseConditionSummaryVariable,
        sekg:CaseAssessmentInstrumentsVariable,
        sekg:CaseFunctionalDomainsVariable,
        sekg:CaseInterventionFocusVariable ;
    sekg:interventionFocus "Pain management, posture improvement, balance, fall reduction, and rollator-use evaluation." .

#################################################################
# Representative sensor recordings
#################################################################

sekg:MEx_Subject01_Exercise01 a sekg:RepresentativeRecording ;
    rdfs:label "MEx subject 01, exercise 01 representative recording" ;
    sekg:hasSourceDataset sekg:MEx ;
    sekg:subjectCode "01" ;
    sekg:exerciseCode "01" ;
    sekg:materializedSample "true"^^xsd:boolean ;
    sekg:sourceArchive "data/external/mex_data.zip" ;
    sekg:sourceArchiveEntry "act/01/01_act_1.csv",
        "acw/01/01_acw_1.csv",
        "dc_0.05_0.05/01/01_dc_1.csv",
        "pm_1.0_1.0/01/01_pm_1.csv" ;
    sekg:sampleFile "data/samples/mex_subject01_exercise01_thigh_accelerometer_sample.csv",
        "data/samples/mex_subject01_exercise01_wrist_accelerometer_sample.csv",
        "data/samples/mex_subject01_exercise01_depth_camera_reduced_sample.csv",
        "data/samples/mex_subject01_exercise01_pressure_mat_reduced_sample.csv" ;
    sekg:hasMeasurement sekg:MEx_ThighAccelerationMeasurement,
        sekg:MEx_WristAccelerationMeasurement,
        sekg:MEx_DepthCameraMeasurement,
        sekg:MEx_PressureMatMeasurement ;
    sekg:hasObservedVariable sekg:TimestampVariable,
        sekg:AccelerationXVariable,
        sekg:AccelerationYVariable,
        sekg:AccelerationZVariable,
        sekg:DepthFeatureVectorVariable,
        sekg:PressureFeatureVectorVariable .

sekg:PhysioNet_GaPt03_01 a sekg:RepresentativeRecording ;
    rdfs:label "PhysioNet GaPt03_01 representative force recording" ;
    sekg:hasSourceDataset sekg:PhysioNetGaitPDB ;
    sekg:subjectCode "GaPt03" ;
    sekg:condition sekg:ParkinsonDisease ;
    sekg:materializedSample "true"^^xsd:boolean ;
    sekg:sampleRateHz "100"^^xsd:decimal ;
    sekg:sensorCount "16"^^xsd:integer ;
    sekg:sourceFile "data/external/physionet_gaitpdb_GaPt03_01.txt" ;
    sekg:supportingMetadataFile "data/external/physionet_gaitpdb_demographics.xls" ;
    sekg:sampleFile "data/samples/physionet_gaitpdb_GaPt03_01_force_sample.csv" ;
    sekg:hasMeasurement sekg:VerticalGroundReactionForceMeasurement ;
    sekg:hasObservedVariable sekg:TimeSecondsVariable,
        sekg:LeftFootSensorForceVariable,
        sekg:RightFootSensorForceVariable,
        sekg:LeftTotalForceVariable,
        sekg:RightTotalForceVariable .

#################################################################
# Measurement modalities and measurement types
#################################################################

sekg:ThighAccelerometer a sekg:SensorModality ;
    rdfs:label "Thigh accelerometer" .

sekg:WristAccelerometer a sekg:SensorModality ;
    rdfs:label "Wrist accelerometer" .

sekg:DepthCamera a sekg:SensorModality ;
    rdfs:label "Depth camera" .

sekg:PressureMat a sekg:SensorModality ;
    rdfs:label "Pressure mat" .

sekg:FootForceSensorArray a sekg:SensorModality ;
    rdfs:label "Foot force sensor array" .

sekg:MEx_ThighAccelerationMeasurement a sekg:MeasurementType ;
    rdfs:label "Thigh acceleration measurement" ;
    sekg:usesModality sekg:ThighAccelerometer .

sekg:MEx_WristAccelerationMeasurement a sekg:MeasurementType ;
    rdfs:label "Wrist acceleration measurement" ;
    sekg:usesModality sekg:WristAccelerometer .

sekg:MEx_DepthCameraMeasurement a sekg:MeasurementType ;
    rdfs:label "Depth-camera movement measurement" ;
    sekg:usesModality sekg:DepthCamera .

sekg:MEx_PressureMatMeasurement a sekg:MeasurementType ;
    rdfs:label "Pressure-mat movement measurement" ;
    sekg:usesModality sekg:PressureMat .

sekg:VerticalGroundReactionForceMeasurement a sekg:MeasurementType ;
    rdfs:label "Vertical ground reaction force measurement" ;
    sekg:usesModality sekg:FootForceSensorArray .

#################################################################
# Clinical concept vocabulary
#################################################################

sekg:ParkinsonDisease a sekg:ClinicalCondition ;
    rdfs:label "Parkinson's disease" .

sekg:CerebralPalsy a sekg:ClinicalCondition ;
    rdfs:label "Cerebral palsy" .

sekg:DevelopmentalImmaturity a sekg:ClinicalCondition ;
    rdfs:label "Developmental immaturity" .

sekg:OccupationalTherapy a sekg:ServiceArea ;
    rdfs:label "Occupational therapy" .

sekg:Physiotherapy a sekg:ServiceArea ;
    rdfs:label "Physiotherapy" .

sekg:ClinicalObservation a sekg:AssessmentInstrument ;
    rdfs:label "Clinical observation" .

sekg:MoCA a sekg:AssessmentInstrument ;
    rdfs:label "Montreal Cognitive Assessment" .

sekg:BOT2 a sekg:AssessmentInstrument ;
    rdfs:label "Bruininks-Oseretsky Test of Motor Proficiency, Second Edition" .

sekg:ModifiedBarthelIndex a sekg:AssessmentInstrument ;
    rdfs:label "Modified Barthel Index" .

sekg:CanadianOccupationalPerformanceMeasure a sekg:AssessmentInstrument ;
    rdfs:label "Canadian Occupational Performance Measure" .

sekg:VASPainScale a sekg:AssessmentInstrument ;
    rdfs:label "Visual analogue pain scale" .

sekg:RangeOfMotionAssessment a sekg:AssessmentInstrument ;
    rdfs:label "Range of motion assessment" .

sekg:ManualMuscleTesting a sekg:AssessmentInstrument ;
    rdfs:label "Manual muscle testing" .

sekg:FunctionalGaitAssessment a sekg:AssessmentInstrument ;
    rdfs:label "Functional gait assessment" .

sekg:AssistiveDeviceReview a sekg:AssessmentInstrument ;
    rdfs:label "Assistive device review" .

sekg:AdaptationAndSeparation a sekg:FunctionalDomain ;
    rdfs:label "Adaptation and separation" .

sekg:Attention a sekg:FunctionalDomain ;
    rdfs:label "Attention" .

sekg:PlayAndInteraction a sekg:FunctionalDomain ;
    rdfs:label "Play and interaction" .

sekg:Cognition a sekg:FunctionalDomain ;
    rdfs:label "Cognition" .

sekg:GrossMotorFunction a sekg:FunctionalDomain ;
    rdfs:label "Gross motor function" .

sekg:FineMotorFunction a sekg:FunctionalDomain ;
    rdfs:label "Fine motor function" .

sekg:ActivitiesOfDailyLiving a sekg:FunctionalDomain ;
    rdfs:label "Activities of daily living" .

sekg:VisualSpatialPerception a sekg:FunctionalDomain ;
    rdfs:label "Visual-spatial perception" .

sekg:Balance a sekg:FunctionalDomain ;
    rdfs:label "Balance" .

sekg:CommunityParticipation a sekg:FunctionalDomain ;
    rdfs:label "Community participation" .

sekg:Pain a sekg:FunctionalDomain ;
    rdfs:label "Pain" .

sekg:Posture a sekg:FunctionalDomain ;
    rdfs:label "Posture" .

sekg:FallsRisk a sekg:FunctionalDomain ;
    rdfs:label "Falls risk" .

sekg:Gait a sekg:FunctionalDomain ;
    rdfs:label "Gait" .

sekg:RangeOfMotion a sekg:FunctionalDomain ;
    rdfs:label "Range of motion" .

sekg:MuscleStrength a sekg:FunctionalDomain ;
    rdfs:label "Muscle strength" .

sekg:AssistiveDeviceUse a sekg:FunctionalDomain ;
    rdfs:label "Assistive device use" .

#################################################################
# Observed variables from current samples
#################################################################

sekg:CaseAgeGroupVariable a sekg:ClinicalVariable ;
    rdfs:label "Age group variable" ;
    sekg:variableName "age_group" ;
    sekg:sourceColumn "kedeea_cases_deidentified.csv:age_group" .

sekg:CaseAssessmentPeriodVariable a sekg:ClinicalVariable ;
    rdfs:label "Assessment period variable" ;
    sekg:variableName "assessment_period" ;
    sekg:sourceColumn "kedeea_cases_deidentified.csv:assessment_period" .

sekg:CaseConditionSummaryVariable a sekg:ClinicalVariable ;
